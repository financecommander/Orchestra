# Orchestra DSL - Environment Variables
#
# Copy this file to .env and fill in your API keys.
# Never commit your .env file – it is already listed in .gitignore.

# ---------------------------------------------------------------------------
# XAI / Grok (required for XAIProvider)
# Obtain your key at https://console.x.ai
# ---------------------------------------------------------------------------
XAI_API_KEY=your_xai_api_key_here

# ---------------------------------------------------------------------------
# Anthropic / Claude (required for AnthropicProvider)
# Obtain your key at https://console.anthropic.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# OpenAI (required for OpenAIProvider)
# Obtain your key at https://platform.openai.com
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ---------------------------------------------------------------------------
# Optional: override the XAI model (default: grok-3-mini)
# ---------------------------------------------------------------------------
# XAI_MODEL=grok-3-mini
